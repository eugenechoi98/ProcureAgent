# ProcureGuard AI 本地 Demo 环境变量示例。
# 这些默认值只适合本机开发和作品集演示，不适合生产环境。

# SQLite 数据库路径。FastAPI 首次启动时会自动创建 schema 和 mock 数据。
DATABASE_PATH=data/procureguard.db

# API 上传文件的本地保存目录。请勿在当前原型中上传真实敏感发票。
UPLOAD_DIR=uploads

# 可选：真实本地 LayoutLMv3 runtime bundle。默认只检查仓库内 ignored runtime 目录。
# 多个候选目录可用 Windows 分号分隔；不要提交 checkpoint、processor 或模型权重。
# PROCUREGUARD_LAYOUTLMV3_CHECKPOINT_DIRS=D:\ProcureAgent_LocalArtifacts\Phase1\layoutlmv3_best

# 可选：真实本地 LoRA rewrite provider。默认关闭，避免普通 API 启动加载 Qwen/LoRA。
# 开启前必须安装 Phase 3 LoRA 依赖，并准备完整 Qwen base model 与 adapter。
# PROCUREGUARD_LORA_ENABLED=1
# PHASE3_MODEL_DIR=D:\ProcureAgent_LocalArtifacts\Phase3\Qwen2.5-0.5B-Instruct
# PROCUREGUARD_LORA_ADAPTER_DIR=D:\ProcureAgent_LocalArtifacts\Phase3\phase3_first_lora_run\phase3\adapters\qwen2.5-0.5b-anomaly-explainer
# PROCUREGUARD_LORA_DEVICE=auto
# PROCUREGUARD_LORA_MAX_NEW_TOKENS=256
# PROCUREGUARD_LORA_SUBPROCESS=1

# 当前代码尚未读取 PROCUREGUARD_ENV、DEMO_MODE/SAMPLE_MODE 或 LOG_LEVEL。
# 为避免产生“已支持环境隔离或日志治理”的错误印象，本示例不设置这些未来变量。
# PROCUREGUARD_ENV=local
# DEMO_MODE=true
# LOG_LEVEL=INFO
